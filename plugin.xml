<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android"
        id="cordova-plugin-firebasex-inappmessaging"
        version="1.0.0">

    <name>cordova-plugin-firebasex-inappmessaging</name>
    <description>Firebase In-App Messaging module for cordova-plugin-firebasex</description>
    <license>MIT</license>
    <keywords>cordova,firebase,in-app messaging,inappmessaging</keywords>

    <engines>
        <engine name="cordova" version=">=12.0.0" />
        <engine name="cordova-android" version=">=14.0.0" />
        <engine name="cordova-ios" version=">=7.0.0" />
    </engines>

    <dependency id="cordova-plugin-firebasex-core" />

    <!-- Android -->
    <platform name="android">
        <preference name="ANDROID_FIREBASE_INAPPMESSAGING_VERSION" default="22.0.2" />

        <framework src="com.google.firebase:firebase-inappmessaging:$ANDROID_FIREBASE_INAPPMESSAGING_VERSION" />
        <framework src="com.google.firebase:firebase-inappmessaging-display:$ANDROID_FIREBASE_INAPPMESSAGING_VERSION" />
    </platform>

    <!-- iOS -->
    <platform name="ios">
        <preference name="IOS_FIREBASE_SDK_VERSION" default="12.9.0-beta" />

        <podspec>
            <config>
                <source url="https://cdn.cocoapods.org/" />
            </config>
            <pods use-frameworks="true">
                <pod name="FirebaseInAppMessaging" spec="12.9.0-beta"/>
            </pods>
        </podspec>

        <hook type="after_plugin_install" src="scripts/ios/after_plugin_install.js" />
    </platform>

</plugin>
